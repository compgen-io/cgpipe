#!/bin/bash


cgpfunc_1() {
JOB_ID="cgpfunc_1"
echo "foo"

}

cgpfunc_2() {
JOB_ID="cgpfunc_2"
echo "bar"

}

cgpfunc_3() {
JOB_ID="cgpfunc_3"
