# VarFloat semantics — literal parsing, type coercion in arithmetic,
# comparison, and print formatting.
#
# Pins CURRENT behavior so the Go port can deliberately match or diverge.
# Notable Java-isms baked in today:
#   - the literal parser is stricter than Float.parseFloat: it filters to
#     [+-]?[0-9]*.?[0-9]* before calling parseDouble, so `1e3` / `Infinity`
#     / `NaN` as source literals become *strings*, not floats
#   - `+1.5` as a literal crashes (tokenizer treats it as binary `+` with
#     missing lhs) — covered indirectly by NOT having a test for it
#   - print formatting strips a trailing ".0" (so 3.0 prints as "3" and 1.
#     prints as "1")
#   - int/int division truncates; int/float widens to float
#   - 1.0 / 0.0 = Infinity (no exception); 0.0 / 0.0 = NaN; -1.0 / 0.0 = -Infinity

print "=== literal parsing ==="
print 1.5
print .5
print 1.
print -1.5
# Float-ish strings the parser DOES NOT accept as floats — they stay strings.
print "1e3"
print "Infinity"
print "NaN"
print "1.5.6"

print "=== int + int stays int, int + float widens ==="
print 1 + 2
print 1 + 2.0
print 1.5 + 2
print 1.5 + 2.5

print "=== division ==="
print 5 / 2
print 5 / 2.0
print 5.0 / 2
print 5.0 / 2.0

print "=== modulo ==="
print 7 % 2
print 7 % 2.0
print 7.5 % 2

print "=== pow always widens to float ==="
print 2 ** 3
print 2 ** -1
print 2.0 ** 3

print "=== comparison across int/float ==="
if 1 < 1.5
print "1 < 1.5 -> true"
endif
if 1.5 > 1
print "1.5 > 1 -> true"
endif
if 1.0 < 2
print "1.0 < 2 -> true"
endif

print "=== print formatting ==="
print 2.0
print -3.0
print 0.1 + 0.2
print -0.5

print "=== edge cases ==="
print 1.0 / 0.0
print -1.0 / 0.0
print 0.0 / 0.0
